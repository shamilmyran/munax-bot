  }
  .planScrollPart {
    width: 100%;

    margin-top: 10px;

    overflow-y: hidden;
    overflow-x: scroll;
    
    display: flex;
    
    align-items: stretch;
    
    flex-direction: row;
    flex-wrap: nowrap;
    
  }
  #mainPageHeadLabel {
    color: white;

    font-family: Courier New;
    font-weight: bold;

    margin-top: 20px;
  }
  #mainPageHead {
    text-shadow: 1px 1px 0 #41db84, 1px -1px 0 #41db84, -1px 1px 0 #41db84, -1px -1px 0 #41db84;

    font-family: Georgia;
    font-weight: bold;
  }
  #mainPagePart {
    position: fixed;
    
    width: 100%;
    
    bottom: 0;

    border-top-left-radius: 20px;
    border-top-right-radius: 20px;

    overflow: scroll;
  }
  #notIndiaBtn {
    background: linear-gradient(to left,#e52266,#db425d);

    color: white;

    width: 80px;
