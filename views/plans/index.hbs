    border-radius: 8px;

    margin-left: 50px;
  }
  #indiaBtn {
    color: white;
    background: linear-gradient(to left,#00ff9d,#2dc378);
    width: 80px;
    height: 40px;

    font-size: 29px;

    border: none;
    border-radius: 8px;


  }
  #indiaBtn:active {
    background: radial-gradient(#39ac5d,#62e98b);
  }
  #countrySelect {
    position: fixed;

    background: linear-gradient(to top,#2e2d35,#0f0f20);

    left: 50%;
    top: 50%;

    transform: translate(-50%,-50%);

    text-align: center;
    justify-content: center;

    border-radius: 5px;

    padding: 50px 0;
  }
  #mainHeddInCountry {
    color: white;

    font-family: Courier;
    font-weight: bold;

    text-shadow: 2px 2px 3px white;
  }
  .howerClass{
    border-color: red;
    box-shadow: 0 0 0 6px #ee1538a4;
  }
</style>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  let stor = window.localStorage,
  rzp, logo;
  loading("body")
  $(document).ready(()=>{
  loading("",true)
  $("#indiaBtn,#notIndiaBtn").click((e)=> {
    var id = $(e.currentTarget).attr("id"),
    type = ""
    if (id === "indiaBtn")type = "inr"
    else type = "doller"
    stor.setItem("money", type)
    toast("Your currency has been selected as "+type.toUpperCase(), "success")
    $("#countrySelect").hide(500)
    $("#planPage").removeAttr('hidden').hide().show(500)
    let h = parseInt($("#pageHeadPart").height())
    $("#mainPagePart").css("top", h+2+"px")
    setMoney()
  })
  function setMoney(){
    $(document).ready(()=>{
      $(".card-title").each((i,e)=>{
        var price=$(e).html().split(",")
        if(stor.getItem("money")==="inr"){
          $(e).html(`<i class="fa fa-inr"></i>${price[0]}/-`)
        }else{
          $(e).html(`<i class="fa fa-dollar"></i>${price[1]}/-`)
        }
      })
    })
  }
  $(".planSelBtn").click(e=>{
    e=$(e.currentTarget)
    loading("body")
    toast("Please Wait..<br>Getting Your Info On Server")
    $.ajax({
      url:"/api/translate/getUser",
      type:"get",
      dataType:"json",
      data:{
        user:"{{id}}"
      },
      success:async(res)=>{
        if(res.sts){
          stor.setItem("plan",e.attr("value"))
          var key=Object.keys(res.data)
          var val=Object.values(res.data)
          var data={}
          key.map((e,i)=>{
            if(typeof val[i] == "object"){
              var k=Object.keys(val[i]),
              v=Object.values(val[i])
              k.map((el,ie)=>{
                data[el]=v[ie]
              })
            }else data[e]=val[i]
          })
          data.path="/html/plans/userData"
          $.ajax({
            url:"/html",
            type:"post",
            dataType:"text",
            data,
            success:(html)=>{
              toast("successfully Getted Your Details\nPlease Check The Data Carefully","success")
              $("#planPage").css("pointer-events","none")
              $("body").append(html)
            }
          })
        }else{
          if(res.msg.toLowerCase().includes("required data")||res.msg.toLowerCase().includes("invalid user")){
            await sleep(5000)
            loading(null,true)
            await toast("Unexpected Error Occured While Getting Your Details \nPlease Go Back To Telegram And Send /plans command and get the right link","error")
            location.href=`https://t.me/subtitle_translate_bot?text=${encodeURIComponent('/plans')}`
          }else toast(res.msg,"error")
          
        }
      }
    })
  })
  var img=document.getElementById("tgwayIcon")
  var can=document.createElement("canvas")
  can.width=img.naturalWidth
  can.height=img.naturalHeight
  var ctx=can.getContext("2d")
  ctx.drawImage(img,0,0,can.width,can.height)
  logo=can.toDataURL()
  })
  $(".card").on("touchstart mouseenter",(e)=>{
    e=$(e.currentTarget)
    $(".card").removeClass("howerClass")
    e.addClass("howerClass")
  })
</script>