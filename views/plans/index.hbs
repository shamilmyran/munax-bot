<section id="countrySelect" class="col-10 col-md-6">
  <div>
    <h3 id="mainHeddInCountry">Are You From India ?</h3>

    <div style="display:flex;justify-content:center">
      <button id="indiaBtn" class="mt-5"><i class="fa fa-check"></i></button>
      <button id="notIndiaBtn" class="mt-5"><i class="fa fa-close"></i></button>
    </div>
  </div>
</section>
<section id="planPage" hidden="true">
  
  <div id="mainPagePart">
    <div style="justify-content:center;text-align:center;margin-top:30px">
      <h4 id="mainPageHead">PLANS PURCHASING PAGE</h4>
      <label id="mainPageHeadLabel">You Can Purchase A Plan <br>For <a href="https://t.me/subtitle_translate_bot" target="_blank"><img src="/images/translate_bot_icon.jpg" alt="Translate Bot" width="40px" style="border-radius:50%"></a> Telegram Bot</label><br><br>
      <label class="text text-info">Available Plans :- </label>
    </div>
    {{#if vip.normal}}
    <div style="width:100;text-align:center">
      <label style="font-family:Courier new;font-weight: bold;color:#00ffe3">You currently have a valid translation plan, and if your daily translation limit is exceeded, you can purchase an Emergency Translation Plan.</label>
    </div>
    {{else}}
    <label class="planType">NORMAL PACK</label>
    <div class="planScrollPart">
      {{#each plans}}
      {{#isEach this.type "==" "normal" this}}
      <div class="card">
        <h5 class="card-header">{{this.plan}}</h5>
        <div class="card-body">
          <h5 class="card-title">{{this.price.inr}},{{this.price.doller}}</h5>
          <label class="validity">validity : {{this.valid}} Days</label>
          <div class="mt-2 mb-2">
          {{#each this.gain}}
            <label class="card-text">
              * {{this}}
            </label><br>
          {{/each}}
          </div>
          <button class="btn btn-primary planSelBtn" value="{{this.plan}}">PURCHASE PLAN</button>
        </div>
      </div>
      {{/isEach}}
      {{/each}}
    </div>
    {{/if}}
    <label class="planType mt-2">Emergency Packs</label>
    <div class="planScrollPart">
      {{#each plans}}
      {{#isEach this.type "==" "addon" this}}
      <div class="card">
        <h5 class="card-header">{{this.plan}}</h5>
        <div class="card-body">
          <h5 class="card-title">{{this.price.inr}},{{this.price.doller}}</h5>
          <label class="validity">validity : {{this.valid}} Days</label>
          <div class="mt-2 mb-2">
          {{#each this.gain}}
            <label class="card-text">
              * {{this}}
            </label><br>
          {{/each}}
          </div>
          <button class="btn btn-primary planSelBtn" value="{{this.plan}}">PURCHASE PLAN</button>
        </div>
      </div>
      {{/isEach}}
      {{/each}}
    </div>
    <div id="mainPageBottomPart" style="justify-content:center;text-align: center" class="mt-3">
      <label id="contactLabel">If You Have Any Doubt About The<br> Plans You Can Contact The Bot Admin</label>
      <div style="display:flex;justify-content:center" class="mt-2">
        <a target="_blank" href="https://t.me/afsalcp66"><button id="contactTelegramBtn"><i class="fa-brands fa-telegram" style="font-size:28px"></i></button></a>
        
        <a target="_blank" href="https://instagram.com/afsal__shazz_"><button id="contactInstagramBtn"><i class="fa-brands fa-instagram" style="font-size:28px"></i></button></a>
      </div>
      <div>
        <p id="discriptionP" style="margin-top:30px">
          Plan Purchasing Is Not Mandatory, If You Like The Translator Bot , And If You Want To Translate More Files Or Remove Ads From The Bot You Can Purchase A Plan For That, There Is No Guarantee About Bot , Sometime It Will Be Down Or Stop Working ,The Bot Admin Is Not Responsible For That,If There Is Any Problem With Plan Purchasing You Can Contact The Bot Admin
        </p>
        <div style="justify-content:center;text-align:center">
          <footer >
          <span id="copyrightSymb">&copy; 2022 TGWAY</span>
          </footer>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .planType{
    color: #eb9fc9;
    
    font-family: Courier New;
    font-size: 15px;
    font-weight: bold;
    
    text-decoration: underline;
    
    margin-left: 20px;
  }
  #copyrightSymb{
    color: white;
    
    font-family: Georgia;
    font-weight: bold;
  }
  #discriptionP{
    color: white;
    
    font-family: Courier New;
  }
  #contactInstagramBtn{
    width: 75px;
    height: 40px;
    
    background: linear-gradient(to bottom left,#9d28d6,#f02b99,#f4c130);
    
    color: white;
    
    border: none;
    border-radius: 5px;
    
    margin-left: 20px;
  }
  #contactInstagramBtn:focus{
    box-shadow: 0 0 0 3px #dd318f99;
  }
  #contactTelegramBtn{
    width: 75px;
    height: 40px;
    
    background: #2b96e9;
    
    color: white;
    
    border: none;
    border-radius: 5px;
    
    transition: .5s;
  }
  #contactTelegramBtn:focus{
    box-shadow: 0 0 0 4px #2c8be6a2;
  }
  #contactLabel{
    color: white;
    
    font-weight: bold;
  }
  .validity{
    color: #23e064;
    
    font-family: Georgia;
    font-weight: bold;
  }
  .card-text{
    color: white;
    
    font-family: Courier New;
    font-weight: bold;
  }
  .card-title{
    color: #2e2d35;
    
    text-shadow: 1px 1px 0 #abeef6,-1px -1px 0 #abeef6,-1px 1px 0 #abeef6,1px -1px 0 #abeef6;
    
    font-family: Courier New;
    font-weight: bold;
  }
  .card-header{
    color: #2e2d35;
    
    background: -webkit-linear-gradient(#9154de,#e330d0);
    -webkit-text-fill-color:transparent;
    -webkit-background-clip:text;
    
    font-family: Georgia;
    font-weight: bold;
  }
  .card{
    width: 300px ;
    
    flex-basis: 300px;
    flex-grow: 0;
    flex-shrink: 0;
    
    margin: 10px;
    
