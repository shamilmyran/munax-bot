#!/usr/bin/env node

/**
* Module dependencies.
*/

var app = require('../app');
var debug = require('debug')('telegrammovie:server');
var http = require('http');
var pdf_socket=require("../bot/pdf-bot/src/socket").io,
got=require("got"),
trans_batch_io=require("../bot/translate-bot/src/batch_translate").io
//var group_io = require("../bot/group-translate/src/socket").io
//var trans_io = require("../bot/translate-bot/src/socket").io

/**
* Get port from environment and store in Express.
*/

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
* Create HTTP server.
*/

var server = http.createServer(app);

server.headersTimout=2000
server.requestTimeout=20000
server.connectionsCheckingInterval=500

server.setTimeout(30000)
/**
* Listen on provided port, on all network interfaces.
*/

server.headersTimout=2000
server.requestTimeout=20000
server.connectionsCheckingInterval=500

server.setTimeout(30000)

server.listen(port);
server.on('error', onError);
server.on('listening', onListening);

/**
* Normalize a port into a number, string, or false.
*/

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
* Event listener for HTTP server "error" event.
*/

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof port === 'string'
  ? 'Pipe ' + port: 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
    }
  }

  /**
  * Event listener for HTTP server "listening" event.
  */

  function onListening() {
    var addr = server.address();
    var bind = typeof addr === 'string'
    ? 'pipe ' + addr: 'port ' + addr.port;
    debug('Listening on ' + bind);
  }

  //trans_io.attach(server)
 // group_io.attach(server)
 
 pdf_socket.attach(server)
 trans_batch_io.attach(server)
 
 process.on("unhandledRejection",async err=>{
   try{
   console.log(err,"unhandledRejection");
   await got.get("https://api.render.com/deploy/srv-ccdhcgirrk0f5cdfvvmg?key=DDtapEdKJ-4")
   process.exit(1)
   }catch(e){}
 })
 process.on("uncaughtException",async err=>{
   try{
   console.log(err,"unhandledException");
   await got.get("https://api.render.com/deploy/srv-ccdhcgirrk0f5cdfvvmg?key=DDtapEdKJ-4")
   process.exit(1)
   }catch(e){}
 })
 
 